		/opt/opencv3-arm/include/opencv2/videostab/fast_marching.hpp \
		/opt/opencv3-arm/include/opencv2/videostab/fast_marching_inl.hpp \
		/opt/opencv3-arm/include/opencv2/videostab/deblurring.hpp \
		/opt/opencv3-arm/include/opencv2/videostab/wobble_suppression.hpp \
		/opt/opencv3-arm/include/opencv2/videostab/ring_buffer.hpp \
		ui_faceattendance.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o faceattendance.o ../FaceAttendance_arm/faceattendance.cpp

qrc_res.o: qrc_res.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o qrc_res.o qrc_res.cpp

####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/FaceAttendance_arm/bin || mkdir -p $(INSTALL_ROOT)/opt/FaceAttendance_arm/bin
	-$(QINSTALL_PROGRAM) $(QMAKE_TARGET) $(INSTALL_ROOT)/opt/FaceAttendance_arm/bin/$(QMAKE_TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) $(INSTALL_ROOT)/opt/FaceAttendance_arm/bin/$(QMAKE_TARGET)
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/FaceAttendance_arm/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

FORCE:

