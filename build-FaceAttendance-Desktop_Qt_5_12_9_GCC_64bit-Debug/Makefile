	$(COPY_FILE) --parents ../FaceAttendance/main.cpp ../FaceAttendance/faceattendance.cpp $(DISTDIR)/
	$(COPY_FILE) --parents ../FaceAttendance/faceattendance.ui $(DISTDIR)/


